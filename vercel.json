{
  "version": 2,
  "projectId": "prj_eyHPDPH1t586T7pWpg9uezgeuBTE",
  "orgId": "team_bhhan7s-projects",
  "builds": [
    {
      "src": "api/reserve.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/reserve",
      "dest": "api/reserve.js",
      "methods": ["POST"]
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
