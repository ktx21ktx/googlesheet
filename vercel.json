{
  "version": 2,
  "builds": [
    {
      "src": "api/reserve.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/reserve",
      "dest": "api/reserve.js",
      "methods": ["POST"]
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ],
  "alias": [
    "googlesheet-gamma.vercel.app"
  ]
}
